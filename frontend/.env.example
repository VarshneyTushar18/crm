# Copy to Vercel → Frontend project → Settings → Environment Variables
# Required for production login and all API calls.
#
# Use your BACKEND (crm) Vercel URL — not the frontend URL.
# Example: https://crm-six-lake.vercel.app/api
VITE_API_BASE_URL=https://YOUR-BACKEND-CRM-PROJECT.vercel.app/api

# Optional: file uploads base (defaults to backend origin)
# VITE_FILE_BASE_URL=https://YOUR-BACKEND-CRM-PROJECT.vercel.app/
